        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta credencial es de %@. ¿Quieres cambiar a %@?"
          }
        }
      }
    },
    "This credential is from %@. It will be saved under that school." : {
      "comment" : "A message that appears when a user's credential is detected to be from a different school than the one they're currently logged into. The argument is the name of the school.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
